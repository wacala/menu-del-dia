{
  "name": "menu-del-dia-backend",
  "version": "0.1.0",
  "description": "Backend API for Menu del Dia - Community food marketplace",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.js\" \"scripts/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" \"scripts/**/*.js\" --fix",
    "db:migrate": "node scripts/migrate.js",
    "prepare": "husky",
    "db:backup": "node scripts/backup-db.js"
  },
  "keywords": [
    "community",
    "food",
    "marketplace",
    "delivery"
  ],
  "author": "Walter",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.64.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "stripe": "^16.12.0",
    "twilio": "^5.8.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.8",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
