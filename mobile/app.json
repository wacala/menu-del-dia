{
  "expo": {
    "name": "Menú del Día",
    "slug": "menu-del-dia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "menu-del-dia",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.menudeldia.app"
    },
    "android": {
      "package": "com.menudeldia.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "webVerifyUrl": "https://menu-del-dia-production.up.railway.app/verify-email"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.menudeldia.app"
        }
      ]
    ]
  }
}
